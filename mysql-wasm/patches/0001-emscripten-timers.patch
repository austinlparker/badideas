diff --git a/mysys/emscripten_timers.c b/mysys/emscripten_timers.c
new file mode 100644
index 0000000..dbd47f1
--- /dev/null
+++ b/mysys/emscripten_timers.c
@@ -0,0 +1,55 @@
+/* Browser-safe timer implementation for the MySQL 5.7 embedded server.
+
+   MySQL's statement timeout facility expects kernel POSIX or kqueue timers.
+   Browsers provide neither. The website never configures statement timeouts,
+   so these objects only need to be valid, cancellable placeholders. */
+
+#include "my_global.h"
+#include "my_timer.h"
+
+#include <errno.h>
+
+int my_timer_initialize(void)
+{
+  return 0;
+}
+
+void my_timer_deinitialize(void)
+{
+}
+
+int my_timer_create(my_timer_t *timer)
+{
+  if (timer == NULL)
+  {
+    errno= EINVAL;
+    return -1;
+  }
+
+  timer->id= 0;
+  return 0;
+}
+
+int my_timer_set(my_timer_t *timer, unsigned long time)
+{
+  (void)timer;
+  (void)time;
+
+  /* Statement execution timeouts are intentionally unsupported. */
+  errno= ENOTSUP;
+  return -1;
+}
+
+int my_timer_cancel(my_timer_t *timer, int *state)
+{
+  (void)timer;
+  if (state != NULL)
+    *state= 1;
+  return 0;
+}
+
+void my_timer_delete(my_timer_t *timer)
+{
+  if (timer != NULL)
+    timer->id= 0;
+}
